# ========================================
# Pro3duct Environment Configuration
# ========================================
# Copy this file to .env and fill in your values

# ── General ──
NODE_ENV=development
APP_NAME=Pro3duct
APP_URL=http://localhost:3000
API_URL=http://localhost:8000

# ── Database ──
DATABASE_URL=postgresql+asyncpg://pro3duct:pro3duct_dev@localhost:5432/pro3duct
DATABASE_SYNC_URL=postgresql://pro3duct:pro3duct_dev@localhost:5432/pro3duct
POSTGRES_USER=pro3duct
POSTGRES_PASSWORD=pro3duct_dev
POSTGRES_DB=pro3duct

# ── Redis ──
REDIS_URL=redis://localhost:6379/0

# ── Object Storage (S3/MinIO) ──
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=pro3duct_minio
S3_SECRET_KEY=pro3duct_minio_secret
S3_BUCKET_ASSETS=pro3duct-assets
S3_BUCKET_MODELS=pro3duct-models
S3_BUCKET_PUBLISHED=pro3duct-published
S3_REGION=us-east-1

# ── Authentication ──
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-change-in-production
JWT_SECRET=your-jwt-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
DEV_AUTO_LOGIN=true
DEV_USER_EMAIL=developer@pro3duct.local
DEV_USER_PASSWORD=development-only
DEV_USER_NAME=Local Developer

# ── Temporal ──
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=pro3duct
TEMPORAL_TASK_QUEUE=generation-pipeline

# ── AI Providers ──
# Meshy
MESHY_API_KEY=
MESHY_API_URL=https://api.meshy.ai

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ── Encryption ──
ENCRYPTION_KEY=your-32-byte-encryption-key-here

# ── CORS ──
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Rate Limiting ──
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

# ── Blender Worker ──
BLENDER_EXECUTABLE=/usr/bin/blender
BLENDER_SCRIPTS_PATH=/app/scripts

# ── Logging ──
LOG_LEVEL=DEBUG
LOG_FORMAT=json
